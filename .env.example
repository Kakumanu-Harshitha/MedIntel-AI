# Hugging Face Token (Optional - helps avoid rate limits and warnings)
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Groq API Key (Required for LLM and Speech-to-Text)
GROQ_API_KEY=your_groq_api_key_here

# Pinecone Configuration (Required for RAG)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=medical-memory

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=health_assistant

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost/dbname

# JWT Secret Key
SECRET_KEY=your_super_secret_jwt_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
